{
  "info": {
    "name": "AeroLink Enterprise E2E API Tests",
    "description": "Integration and API Tests for all AeroLink Microservices (Booking, Flight, Baggage)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Flight Service",
      "item": [
        {
          "name": "Get All Flights",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://{{flight_url}}/flights",
              "protocol": "http",
              "host": ["{{flight_url}}"],
              "path": ["flights"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "2. Booking Service",
      "item": [
        {
          "name": "User Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser1\",\n  \"password\": \"testpass123\",\n  \"email\": \"testuser1@aerolink.com\"\n}"
            },
            "url": {
              "raw": "http://{{booking_url}}/auth/register",
              "protocol": "http",
              "host": ["{{booking_url}}"],
              "path": ["auth", "register"]
            }
          },
          "response": []
        },
        {
          "name": "User Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"access_token\", jsonData.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "testuser1",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "testpass123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "http://{{booking_url}}/auth/login",
              "protocol": "http",
              "host": ["{{booking_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Get User Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://{{booking_url}}/auth/me",
              "protocol": "http",
              "host": ["{{booking_url}}"],
              "path": ["auth", "me"]
            }
          },
          "response": []
        },
        {
          "name": "Create Booking",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"booking_id\", jsonData.booking_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"flight_number\": \"AL-1024\",\n  \"passenger_name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "http://{{booking_url}}/bookings",
              "protocol": "http",
              "host": ["{{booking_url}}"],
              "path": ["bookings"]
            }
          },
          "response": []
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "http://{{booking_url}}/bookings/{{booking_id}}",
              "protocol": "http",
              "host": ["{{booking_url}}"],
              "path": ["bookings", "{{booking_id}}"]
            }
          },
          "response": []
        },
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"admin_token\", jsonData.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "admin",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "admin123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "http://{{booking_url}}/auth/login",
              "protocol": "http",
              "host": ["{{booking_url}}"],
              "path": ["auth", "login"]
            }
          },
          "response": []
        },
        {
          "name": "Admin View All Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": {
              "raw": "http://{{booking_url}}/admin/bookings",
              "protocol": "http",
              "host": ["{{booking_url}}"],
              "path": ["admin", "bookings"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "3. Baggage Service",
      "item": [
        {
          "name": "Update Baggage",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"baggage_id\", jsonData.baggage_id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"booking_id\": \"{{booking_id}}\",\n  \"status\": \"CHECKED_IN\",\n  \"location\": \"Counter A\"\n}"
            },
            "url": {
              "raw": "http://{{baggage_url}}/baggage/update",
              "protocol": "http",
              "host": ["{{baggage_url}}"],
              "path": ["baggage", "update"]
            }
          },
          "response": []
        },
        {
          "name": "Get Baggage Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://{{baggage_url}}/baggage/{{baggage_id}}",
              "protocol": "http",
              "host": ["{{baggage_url}}"],
              "path": ["baggage", "{{baggage_id}}"]
            }
          },
          "response": []
        }
      ]
    }
