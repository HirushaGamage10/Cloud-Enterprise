        <hashTree/>
        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="7. Cancel Booking" enabled="true">
          <stringProp name="HTTPSampler.domain">a11a9d18900774a5fb2a27608414d622-2022026360.eu-west-1.elb.amazonaws.com</stringProp>
