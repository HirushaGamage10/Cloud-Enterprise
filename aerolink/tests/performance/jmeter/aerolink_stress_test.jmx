        <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="9. Admin View All Bookings" enabled="true">
          <stringProp name="HTTPSampler.domain">a11a9d18900774a5fb2a27608414d622-2022026360.eu-west-1.elb.amazonaws.com</stringProp>
          <stringProp name="HTTPSampler.port">80</stringProp>
          <stringProp name="HTTPSampler.protocol">http</stringProp>
          <stringProp name="HTTPSampler.path">/admin/bookings</stringProp>
